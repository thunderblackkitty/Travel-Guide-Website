<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body class="d-flex flex-column min-vh-100" style="background-color: rgb(190, 190, 190); font-family: Arial, Helvetica, sans-serif;">
    <nav class="navbar navbar-expand-lg" style="background-color: whitesmoke;">
        <div class="container">
            <a class="navbar-brand">
                <img src="images/download.png" alt="logo" width="130px" height="100px">
            </a>
            <button class="navbar-toggler" type="Button" data-bs-toggle="collapse" data-bs-target="#menu">
            <span class="navbar-toggler-icon"> </span>
        </button>
 
        <div class="collapse navbar-collapse" id="menu">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item"><a href="home.html" class="nav-link"> <i class="bi bi-house"></i> Home </a></li>
                <li class="nav-item"><a href="explore.html" class="nav-link"> <i class="bi bi-compass"></i> Explore </a></li>
                <li class="nav-item"><a href="travelinfo.html" class="nav-link"> <i class="bi bi-info-circle"></i> Travel Info </a></li>
                <li class="nav-item"><a href="about.html" class="nav-link"> <i class="bi bi-person"></i> About </a></li>
                <li class="nav-item"><a href="contact.html" class="nav-link"><i class="bi bi-telephone"></i>Contact</a></li>
            </ul>
            <button type="button" class="btn btn-light ms-3" data-bs-toggle="modal" data-bs-target="#myModal"> Sign Up </button>
            <button type="button" class="btn btn-light ms-3" data-bs-toggle="modal" data-bs-target="#myModal1"> Log in </button>
        </div>
        <div class="modal fade" id="myModal">
        <div class="modal-dialog modal-md modal-dialogue-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title"> Sign Up </h3>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
 
           
                <div class="modal-body">
                    <form>
                        <div class="mb-3">
                            <label for="email" class="form-label"> Email Address </label>
                            <input type="email" class="form-control" id="email" placeholder="Enter your email">
                        </div>

                        <div class="mb-3">
                            <label for="username" class="form-label"> Username </label>
                            <input type="text" class="form-control" id="username" placeholder="Enter your username">
                        </div> 

                        <div class="mb-3">
                            <label for="birthdate" class="form-label"> Birthdate </label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="birthdate" placeholder="Enter your birthdate">
                                <span class="input-group-text">
                                    <i class="bi bi-calendar"></i>
                                </span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label d-block">Gender</label>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio"
                                name="gender" id="male" value="male">
                                <label class="form-check-label" for="male">Male</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="gender" id="female" value="female">
                                <label class="form-check-label" for="female">Female</label>
                            </div>
                        </div>
 
                        <div class="mb-3">
                            <label for="password" class="form-label"> Password </label>
                            <input type="text" class="form-control" id="password" placeholder="Enter your password">
                        </div>

                        <div class="pt-2">
                        <input type="checkbox" id="agree1">
                        <label for="agree1"> I agree to the terms and agreements.</label><br>
                        <input type="checkbox" id="agree2">
                        <label for="agree2"> I agree to the privacy policy.</label><br>
                        <p class="text-end pt-5" style="font-size: 15px;">Already have an account? <a href="myModal1" data-bs-toggle="modal" data-bs-target="#myModal1" data-bs-dismiss="modal"> Log in </a></p>
                        </div>
 
                    </form>
                </div>
 
                <div class="modal-footer justify-content-center p-4">
                    <button type="button" class="btn btn-lg btn-primary" data-bs-dismiss="modal">Sign Up</button>
                </div>
            </div>
        </div>
    </div>
 
    <div class="modal fade" id="myModal1">
        <div class="modal-dialog modal-md modal-dialogue-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title"> Login </h3>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
 
           
                <div class="modal-body">
                    <form>
                        <div class="mb-3">
                            <label for="email" class="form-label"> Email Address </label>
                            <input type="email" class="form-control" id="email" placeholder="Enter your email">
                        </div>
 
                        <div class="mb-3">
                            <label for="password" class="form-label"> Password </label>
                            <input type="text" class="form-control" id="password" placeholder="Enter your password">
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label"> Confirmed Password </label>
                            <input type="text" class="form-control" id="password" placeholder="Enter you confirmed password">
                        </div>

                        <div class="pt-2">
                        <input type="checkbox" id="agree1">
                        <label for="agree1"> I agree to the terms and agreements.</label><br>
                        <input type="checkbox" id="agree2">
                        <label for="agree2"> I agree to the privacy policy.</a></label><br>
                        <p class="text-end pt-5" style="font-size: 15px;">Creat New Account? <a href="myModal" data-bs-toggle="modal" data-bs-target="#myModal" data-bs-dismiss="modal"> Sign Up </a></p>
                        </div>
 
                    </form>
                </div>
 
                <div class="modal-footer justify-content-center p-4">
                    <button type="button" class="btn btn-lg btn-primary" data-bs-dismiss="modal"> Login </button>
                </div>
            </div>
        </div>
    </div>
    </nav>

    <div id="demo" class="carousel slide" data-bs-ride="carousel">
        <!-- Indicators/dots -->
         <div class="carousel-indicators">
            <button type="button" data-bs-target="#demo" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="2"></button>
         </div>
         <!-- The slideshow/carousel -->
          <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="images/wy.png" alt="Berlin" class="d-block" style="width:100%">
                <div class="carousel-caption">
                    <h3>Let's Explore Winschoten</h3>
                    <p>Discover the heart of the Oldambt region — where history, nature, and culture come together.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="images/ay.png" alt="Würzburg" class="d-block" style="width:100%">
                <div class="carousel-caption">
                    <h3>Relax by the Water</h3>
                    <p>Enjoy peaceful canals, scenic parks, and the beauty of northeastern Netherlands.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="images/oy.png" alt="ff" class="d-block" style="width:100%">
                <div class="carousel-caption">
                    <h3>Experience Local Culture</h3>
                    <p>Stroll through charming streets, visit markets, and explore Winschoten’s rich heritage.</p>
                </div>
            </div>
          </div>

          <!-- Left and right controls/icons -->
           <button class="carousel-control-prev" type="button" data-bs-target="#demo" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
           </button>
           <button class="carousel-control-next" type="button" data-bs-target="#demo" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
           </button>
    </div>

    <div class="container py-5">
  <div class="row align-items-center">
    
    <!-- Text Content -->
    <div class="col-md-6">
      <h2 class="mb-3">Discover Winschoten</h2>
      <p>
        Winschoten is a charming town in the northeast of the Netherlands,<br>
         known for its scenic parks, peaceful canals, and rich cultural heritage.
      </p>
      <p>
        Whether you're looking to relax in nature, explore local markets,<br>
         or enjoy a quiet getaway, Winschoten offers a perfect mix of <br> 
         beauty and simplicity.
      </p>
      <a href="#" class="btn btn-primary mt-3">Learn More</a>
    </div>

    <!-- Image -->
    <div class="col-md-6">
      <img src="images/WINSCHOTEN-001JPG-1024x683-jpg.webp" alt="Winschoten view" class="img-fluid rounded shadow">
    </div>

  </div>
    </div>

    <div class="container mb-5">
    <h2 class="text-black text-center mb-5">Top Attractions</h2>
    <div class="row">
        <div class="col-md-4">
            <div class="card rounded ">
                <img src="images/SPRQCx_1581806050_rosssssssss.jpg" class="card-img-top">
                <div class="card-body">
                    <h5 class="card-title">Rosarium Winschoten</h5>
                    <p class="card-text"> A unique experience that combines <br>
                        art and history. </p>
                    <a href="explore.html" class="btn btn-primary">More</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card rounded">
                <img src="images/Untitled design.png" class="card-img-top">
                <div class="card-body">
                    <h5 class="card-title">Museum Stoomgemaal Winschoten</h5>
                    <p class="card-text"> Explore the preserved steam pumping stations<br>
                         that once kept the Netherlands dry.</p>
                    <a href="explore.html" class="btn btn-primary">More</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card rounded">
                <img src="images/10.jpg" class="card-img-top">
                <div class="card-body">
                    <h5 class="card-title">Gallery Marten Randa</h5>
                    <p class="card-text">A place to appreciate the art and culture <br> of the region.</p>
                    <a href="explore.html" class="btn btn-primary">More</a>
                </div>
            </div>
        </div>
    </div>
    </div>

    <div id="explore" class="container py-5">
        <h2 class="text-center mb-5">Things to Do</h2>

        <div class="row text-center">
            <div class="col-md-4 mb-4">
                <div class="p-4 rounded h-100 bg-white">
                    <h4>Outdoor Activities</h4>
                    <p>Enjoy cycling routes, walking trails, and peaceful canals.</p>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="p-4 rounded h-100 bg-white">
                    <h4>Nature & Parks</h4>
                    <p>Relax in green parks and explore scenic natural areas.</p>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="p-4 rounded h-100 bg-white">
                    <h4>Culture</h4>
                    <p>Visit museums and discover local history and traditions.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="py-5">
        <div class="container">
            <h2 class="text-center mb-5">Food & Stay</h2>

            <div class="row">
                <!-- Food -->
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <img src="images/hotel.png" class="card-img-top">
                        <div class="card-body">
                            <h5 class="card-title">Local Food</h5>
                                <p class="card-text">
                                    Taste Dutch cuisine, cozy cafés, and local restaurants offering fresh and delicious meals.
                                </p>
                        </div>
                    </div>
                </div>

                <!-- Stay -->
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <img src="images/winschoten-city-hotel.webp" class="card-img-top">
                        <div class="card-body">
                            <h5 class="card-title">Accommodation</h5>
                                <p class="card-text">
                                    Find comfortable hotels, guesthouses, and budget-friendly stays for a relaxing visit.
                                </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="py-5">
        <div class="container">
            <h2 class="text-center mb-5">Travel Tips</h2>

            <div class="row text-center">
                <div class="col-md-4 mb-4">
                    <div class="p-4 rounded h-100 bg-white">
                        <h5>Best Time to Visit</h5>
                        <p>Spring and summer offer the best weather and beautiful scenery.</p>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="p-4 rounded h-100 bg-white">
                        <h5>Getting There</h5>
                        <p>Winschoten is easily accessible by train and road from Groningen.</p>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="p-4 rounded h-100 bg-white">
                        <h5>Local Tips</h5>
                        <p>Bring a bike and explore like a local for the best experience.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

